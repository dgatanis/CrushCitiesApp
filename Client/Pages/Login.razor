@page "/login"
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<AuthorizeView>
    <Authorized Context="authState">
        <RedirectToHome />
    </Authorized>
    <NotAuthorized Context="anonState">
        <h1>Login</h1>

        <EditForm Model="model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <InputText id="username" class="form-control" @bind-Value="model.Username" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" class="form-control" type="password" @bind-Value="model.Password" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <button type="submit" class="btn btn-primary">Log in</button>
            <a class="btn btn-link" href="/register">Create account</a>
        </EditForm>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly LoginViewModel model = new();
    private string? errorMessage;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        errorMessage = null;
        var success = await AuthService.LoginAsync(model.Username, model.Password);
        if (!success)
        {
            errorMessage = "Invalid username or password.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Absolute, out var returnUri))
        {
            Navigation.NavigateTo(returnUri.PathAndQuery, true);
            return;
        }

        Navigation.NavigateTo("/", true);
    }

    private sealed class LoginViewModel
    {
        [Required]
        public string Username { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
