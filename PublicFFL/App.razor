@using Shared.Services
<CascadingValue Name="AppBrand" Value="@("Public FFL")">
    <Router AppAssembly="@typeof(App).Assembly"
            AdditionalAssemblies="new[] { typeof(Shared.Pages.Home).Assembly }"
            NotFoundPage="typeof(Shared.Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(Shared.Layout.MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingValue>

@code {
    [Inject] private Shared.Services.PlayerState PlayerState { get; set; } = default!;
    [Inject] private Shared.Services.RosterState RosterState { get; set; } = default!;
    [Inject] private Shared.Services.LeagueState LeagueState { get; set; } = default!;
    [Inject] private Shared.Services.UserState UserState { get; set; } = default!;

    /// <summary>
    /// Initializes rest of sleeper data for the app on startup
    /// </summary>
    /// <returns></returns>
    protected override async Task OnInitializedAsync()
    {
        string? current_league_id = await LeagueState.GetCurrentLeagueId();


        try{
            if(!PlayerState.IsLoaded)
                await PlayerState.SetPlayers(true); 
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading player data on startup: {ex.Message}");
        }


        try {
            if (!RosterState.IsLoaded)
                await RosterState.SetRosters(current_league_id ?? string.Empty, true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading roster data on startup: {ex.Message}");
        }


        try {
            if (!LeagueState.IsLoaded)
                await LeagueState.SetLeague(current_league_id ?? string.Empty, true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading league data on startup: {ex.Message}");
        }


        try{
            if (!UserState.IsLoaded)
                await UserState.SetUsers(current_league_id ?? string.Empty, true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user data on startup: {ex.Message}");
        }
    }

}
