@page "/history/champs"
@using Shared.Models
@using Shared.Services
@inject PlayoffState PlayoffState 
@inject RosterState RosterState
@inject LeagueState LeagueState
@inject PlayerState PlayerState
@inject UserState UserState

<PageTitle>League Champs</PageTitle>

<div class="d-flex justify-content-center">
    <h1>League Champs</h1>    
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else
{
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-10">
                @foreach(var seasonBracket in _winnersBrackets)
                {
                    var leagueId = seasonBracket.Key;
                    <div class="mt-4">
                        <div class="row g-3 justify-content-center">
                            @foreach(var bracket in seasonBracket.Value)
                            {
                                if(bracket.PlacementGame == 1 && LeagueState.AllLeagues is not null)
                                {
                                    var league = LeagueState.AllLeagues.FirstOrDefault(x => x.LeagueId == leagueId);
                                    var finalWeek = league is not null 
                                                            ? league.Settings?.LastScoredLeg.ToString() 
                                                            : "";
                                    var winningMatchup = _winnersMatchups.FirstOrDefault(x => x.RosterId == bracket.WinnerId && x.LeagueId == leagueId && x.Week == finalWeek);
                                    var highScorer = winningMatchup is not null && winningMatchup.PlayersPoints is not null && winningMatchup.Starters is not null
                                                            ? winningMatchup.PlayersPoints
                                                                .Where(x => x.Key is not null && winningMatchup.Starters.Contains(x.Key))
                                                                .OrderByDescending(x => x.Value)
                                                                .FirstOrDefault()
                                                            : default;
                                    var highScorerPlayer = highScorer.Key is not null && PlayerState.PlayerById.TryGetValue(highScorer.Key, out var playerId)
                                                            ? playerId
                                                            : null;
                                    var userId = bracket.WinnerId is not null && RosterState.UserIdByRosterId.TryGetValue(bracket.WinnerId.ToString() ?? "", out var user_id)
                                                            ? user_id
                                                            : null;
                                    if(winningMatchup is not null && league is not null && highScorerPlayer is not null)
                                    {
                                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                                            <div class="card h-100 shadow-sm w-100 text-center mt-2 common-container border-3">
                                                <div class="card-body">
                                                    <div class="text-muted small mb-1" style="color:#bababa !important;">@league.Season</div>
                                                    <div>
                                                        <img class="owner-avatar" src="@(UserState.OwnerAvatarByUserId.TryGetValue(userId ?? "", out var link) ? link : $"Not Found")">
                                                    </div>
                                                    <div class="fs-5 fw-semibold">
                                                        @(bracket.WinnerId is int id && RosterState.TeamNameByRosterId.TryGetValue(id, out var name) ? name : "(unknown)")
                                                    </div>
                                                    <div class="mt-4 medium">King of the Finals</div>
                                                    <div class="d-flex justify-content-center align-items-center mt-2">
                                                        <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(highScorerPlayer.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp); border-color:var(--@(highScorerPlayer.Position))"></div>
                                                        <div class="fs-6">@highScorerPlayer.Firstname @highScorerPlayer.Lastname</div>
                                                    </div>
                                                    <div class="text-muted small" style="font-family: 'F2';">@highScorer.Value Points</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                }
                @foreach(var season in _previousChamps)
                {
                    var userId = RosterState.UserIdByRosterId.TryGetValue(season.Value.ToString() ?? "", out var user_id)
                        ? user_id
                        : null;

                    <div class="mt-4">
                        <div class="row g-3 justify-content-center">
                            <div class="col-12 col-md-6 col-lg-4 d-flex">
                                <div class="card h-100 shadow-sm w-100 text-center mt-2 common-container border-3">
                                    <div class="card-body">
                                        <div class="text-muted small mb-1" style="color:#bababa !important;">@season.Key</div>
                                        <div>
                                            <img class="owner-avatar" src="@(UserState.OwnerAvatarByUserId.TryGetValue(userId ?? "", out var link) ? link : $"Not Found")">
                                        </div>
                                        <div class="fs-5 fw-semibold">
                                            @(RosterState.TeamNameByRosterId.TryGetValue(season.Value, out var name) ? name : "(unknown)")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private List<MatchupModel> _winnersMatchups = new();
    private List<MatchupModel> _losersMatchups = new();
    private Dictionary<string, List<PlayoffBracketsModel>> _winnersBrackets = new();
    private Dictionary<string, List<PlayoffBracketsModel>> _losersBrackets = new();
    private Dictionary<string, int> _previousChamps = new ();

    protected override async Task OnInitializedAsync()
    {
        await PlayoffState.EnsureLoadedAsync();
        await RosterState.EnsureLoadedAsync();

        LoadPreviousChamps();
        _winnersMatchups = PlayoffState.WinnersBracketMatchups;
        _losersMatchups = PlayoffState.LosersBracketMatchups;
        _winnersBrackets = PlayoffState.AllWinnersBrackets;
        _losersBrackets = PlayoffState.AllLosersBrackets;
        _isLoading = false;
    }


    /// <summary>
    /// Load previous champs 
    /// </summary>
    private void LoadPreviousChamps()
    {
        // Add season and rosterid for previous champions not included in sleeper data
        _previousChamps.Add("2023", 10);
        _previousChamps.Add("2022", 2);
        _previousChamps.Add("2021", 4);
        _previousChamps.Add("2020", 7);
    }
}
