@page "/history/stats"
@using Shared.Models
@using Shared.Services
@inject UserState UserState
@inject RosterState RosterState
@inject PlayerState PlayerState
@inject LeagueState LeagueState
@inject StatsData StatsData

<PageTitle>Stats | @Brand</PageTitle>

<div class="d-flex justify-content-center">
    <h1>Stats</h1>
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else 
{
    <div class="container">
        <div class="row justify-content-center g-4">
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Lowest Scoring Teams</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _lowScoringTeams ?? [])
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@t.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Top Scoring Teams</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _topScoringTeams ?? [])
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@t.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Lowest Scoring Starters</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Player</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _lowScoringPlayers ?? [])
                        {
                            var playerPoints = (t.PlayersPoints ?? Enumerable.Empty<KeyValuePair<string, double>>())
                                                                    .Where(kv => t.Starters != null && t.Starters.Contains(kv.Key))
                                                                    .OrderBy(kv => kv.Value)
                                                                    .FirstOrDefault();
                            var player = PlayerState.PlayerById.TryGetValue(playerPoints.Key, out var p) ? p : null;
                            if(player is not null)
                            {
                                <tr>
                                    <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                    <td>@player.Firstname @player.Lastname</td>
                                    <td>@playerPoints.Value</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Top Scoring Starters</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Player</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _topScoringPlayers ?? [])
                        {
                            var playerPoints = (t.PlayersPoints ?? Enumerable.Empty<KeyValuePair<string, double>>())
                                                                        .Where(kv => t.Starters != null && t.Starters.Contains(kv.Key))
                                                                        .OrderByDescending(kv => kv.Value)
                                                                        .FirstOrDefault();
                            var player = PlayerState.PlayerById.TryGetValue(playerPoints.Key, out var p) ? p : null;
                            if(player is not null)
                            {
                                <tr>
                                    <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                    <td>@player.Firstname @player.Lastname</td>
                                    <td>@playerPoints.Value</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Most High-Scoring Weeks</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Weeks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _highScoringWeeksByRosterId
                            .OrderByDescending(kv => kv.Value)
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Most Low-Scoring Weeks</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Weeks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _lowScoringWeeksByRosterId
                            .OrderByDescending(kv => kv.Value)
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Largest Margins of Victory</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Margin</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _largestMarginOfVictory ?? [])
                        {
                            var t = kv.Key;
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@kv.Value.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">Tightest Margins of Victory</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Margin</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _tightestMarginOfVictory ?? [])
                        {
                            var t = kv.Key;
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@kv.Value.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <h3 class="h5 text-center mb-3">All-Time Records</h3>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Record</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _recordByRosterId
                            .OrderByDescending(kv =>
                            {
                                var parts = kv.Value.Split('-', StringSplitOptions.TrimEntries);
                                return parts.Length > 0 && int.TryParse(parts[0], out var wins) ? wins : 0;
                            })
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


@code {
    [CascadingParameter(Name = "AppBrand")]
    private string? AppBrand { get; set; }
    private string Brand => string.IsNullOrWhiteSpace(AppBrand) ? "FFL" : AppBrand;
    private bool _isLoading = true;

    private List<MatchupModel> _topScoringTeams = new();
    private List<MatchupModel> _lowScoringTeams = new();
    private List<MatchupModel> _topScoringPlayers = new();
    private List<MatchupModel> _lowScoringPlayers = new();
    private Dictionary<int, string> _recordByRosterId = new Dictionary<int, string>();
    private Dictionary<int, int> _highScoringWeeksByRosterId = new Dictionary<int, int>();
    private Dictionary<int, int> _lowScoringWeeksByRosterId = new Dictionary<int, int>();
    private List<KeyValuePair<MatchupModel, double>> _largestMarginOfVictory = new();
    private List<KeyValuePair<MatchupModel, double>> _tightestMarginOfVictory = new();


    protected override void OnInitialized()
    {
        _isLoading = true;
        _ = LoadPageAsync();
    }

    /// <summary>
    /// Loads all elements needed for the page
    /// </summary>
    /// <returns></returns>
    private async Task LoadPageAsync()
    {
        try
        {
            await Task.Yield();
            await StatsData.EnsureLookupsLoadedAsync();
            await LeagueState.EnsureLoadedAsync();

            _topScoringTeams = StatsData.TopScoringTeams.Take(10).ToList() ?? [];
            _lowScoringTeams = StatsData.LowScoringTeams.Take(10).ToList() ?? [];
            _topScoringPlayers = StatsData.TopScoringPlayers.Take(10).ToList() ?? [];
            _lowScoringPlayers = StatsData.LowScoringPlayers.Take(10).ToList() ?? [];
            _largestMarginOfVictory = StatsData.LargestMarginOfVictory.Take(10).ToList() ?? [];
            _tightestMarginOfVictory = StatsData.TightestMarginOfVictory.Take(10).ToList() ?? [];
            _recordByRosterId = SumRecords(StatsData.RecordsBySeason) ?? new Dictionary<int, string>();
            _highScoringWeeksByRosterId = SumHighScoringWeeks(StatsData.HighScoringWeeksByRosterId) ?? new Dictionary<int, int>();
            _lowScoringWeeksByRosterId = StatsData.LowScoringWeeksByRosterId?.ToDictionary() ?? new Dictionary<int, int>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats page: {ex.Message}");
            _isLoading = false;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Dictionary<int, string> SumRecords(IReadOnlyDictionary<string, SeasonRecord> season_records)
    {
        var totals = new Dictionary<int, Record>();

        var playoffStartBySeason = LeagueState.AllLeagues
            .Where(l => !string.IsNullOrWhiteSpace(l.Season) && l.Settings?.PlayoffWeekStart is int)
            .GroupBy(l => l.Season!)
            .ToDictionary(g => g.Key, g => g.First().Settings!.PlayoffWeekStart);

        foreach (var seasonEntry in season_records)
        {
            var season = seasonEntry.Key;
            var seasonRecord = seasonEntry.Value;

            if (!playoffStartBySeason.TryGetValue(season, out var playoffStart))
            {
                continue;
            }

            var cutoffWeek = playoffStart > 0 ? playoffStart - 1 : int.MaxValue;
            var latestWeek = seasonRecord.WeeksByNumber.Keys
                .Where(w => w <= cutoffWeek)
                .DefaultIfEmpty(0)
                .Max();

            if (latestWeek == 0) continue;

            if (!seasonRecord.WeeksByNumber.TryGetValue(latestWeek, out var weekRecord)) continue;

            foreach (var kv in weekRecord.ByRoster)
            {
                if (!totals.TryGetValue(kv.Key, out var record))
                {
                    record = new Record();
                    totals[kv.Key] = record;
                }

                record.Wins += kv.Value.Wins;
                record.Losses += kv.Value.Losses;
                record.Ties += kv.Value.Ties;
            }
        }

        var result = new Dictionary<int, string>();
        foreach (var kv in totals)
        {
            result[kv.Key] = kv.Value.Display;
        }

        return result;
    }

    private static Dictionary<int, int> SumHighScoringWeeks(IReadOnlyDictionary<string, Dictionary<int, int>> bySeason)
    {
        var totals = new Dictionary<int, int>();
        foreach (var season in bySeason.Values)
        {
            foreach (var kv in season)
            {
                if (totals.TryGetValue(kv.Key, out var count))
                {
                    totals[kv.Key] = count + kv.Value;
                }
                else
                {
                    totals[kv.Key] = kv.Value;
                }
            }
        }
        return totals;
    }
}

