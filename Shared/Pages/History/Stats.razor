@page "/history/stats"
@using Microsoft.Extensions.Logging
@using Shared.Models
@using Shared.Services
@inject ILogger<Stats> ILogger
@inject UserState UserState
@inject RosterState RosterState
@inject PlayerState PlayerState
@inject LeagueState LeagueState
@inject StatsData StatsData


<PageTitle>Stats | @Brand</PageTitle>


<div class="d-flex justify-content-center">
    <h1>Stats</h1>
</div>


@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else 
{
    <div class="container">
        <div class="row justify-content-center g-4">
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Lowest Scoring Teams</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _lowScoringTeams ?? [])
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@t.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>


            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Top Scoring Teams</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _topScoringTeams ?? [])
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@t.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Lowest Scoring Starters</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Player</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _lowScoringPlayers ?? [])
                        {
                            var playerPoints = (t.PlayersPoints ?? Enumerable.Empty<KeyValuePair<string, double>>())
                                                                    .Where(kv => t.Starters != null && t.Starters.Contains(kv.Key))
                                                                    .OrderBy(kv => kv.Value)
                                                                    .FirstOrDefault();
                            var player = PlayerState.PlayerById.TryGetValue(playerPoints.Key, out var p) ? p : null;
                            if(player is not null)
                            {
                                <tr>
                                    <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                    <td>@player.Firstname @player.Lastname</td>
                                    <td>@playerPoints.Value</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Top Scoring Starters</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Player</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var t in _topScoringPlayers ?? [])
                        {
                            var playerPoints = (t.PlayersPoints ?? Enumerable.Empty<KeyValuePair<string, double>>())
                                                                        .Where(kv => t.Starters != null && t.Starters.Contains(kv.Key))
                                                                        .OrderByDescending(kv => kv.Value)
                                                                        .FirstOrDefault();
                            var player = PlayerState.PlayerById.TryGetValue(playerPoints.Key, out var p) ? p : null;
                            if(player is not null)
                            {
                                <tr>
                                    <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                    <td>@player.Firstname @player.Lastname</td>
                                    <td>@playerPoints.Value</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Most High-Scoring Weeks</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Weeks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _highScoringWeeksByRosterId
                            .OrderByDescending(kv => kv.Value)
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Most Low-Scoring Weeks</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Weeks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _lowScoringWeeksByRosterId
                            .OrderByDescending(kv => kv.Value)
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Largest Margins of Victory</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Margin</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _largestMarginOfVictory ?? [])
                        {
                            var t = kv.Key;
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@kv.Value.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>


            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">Tightest Margins of Victory</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Margin</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _tightestMarginOfVictory ?? [])
                        {
                            var t = kv.Key;
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(t.RosterId, out var name) ? name : "")</td>
                                <td>@kv.Value.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="col-12 col-lg-6">
                <div class="text-center mb-3 fs-4">All-Time Records</div>
                <table class="table table-sm table-bordered text-center align-middle stats-table">
                    <thead>
                        <tr>
                            <th>Team</th>
                            <th>Record</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kv in _recordByRosterId
                            .OrderByDescending(kv =>
                            {
                                var parts = kv.Value.Split('-', StringSplitOptions.TrimEntries);
                                return parts.Length > 0 && int.TryParse(parts[0], out var wins) ? wins : 0;
                            })
                            .ThenBy(kv => kv.Key))
                        {
                            <tr>
                                <td>@(RosterState.TeamNameByRosterId.TryGetValue(kv.Key, out var name) ? name : "")</td>
                                <td>@kv.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


@code {
    [CascadingParameter(Name = "AppBrand")]
    private string? AppBrand { get; set; }
    private string Brand => string.IsNullOrWhiteSpace(AppBrand) ? "FFL" : AppBrand;
    private bool _isLoading = true;

    private List<MatchupModel> _topScoringTeams = new();
    private List<MatchupModel> _lowScoringTeams = new();
    private List<MatchupModel> _topScoringPlayers = new();
    private List<MatchupModel> _lowScoringPlayers = new();
    private Dictionary<int, string> _recordByRosterId = new Dictionary<int, string>();
    private Dictionary<int, int> _highScoringWeeksByRosterId = new Dictionary<int, int>();
    private Dictionary<int, int> _lowScoringWeeksByRosterId = new Dictionary<int, int>();
    private List<KeyValuePair<MatchupModel, double>> _largestMarginOfVictory = new();
    private List<KeyValuePair<MatchupModel, double>> _tightestMarginOfVictory = new();



    protected override void OnInitialized()
    {
        _isLoading = true;
        _ = LoadPageAsync();
    }

    /// <summary>
    /// Loads all elements needed for the page
    /// </summary>
    /// <returns></returns>
    private async Task LoadPageAsync()
    {
        try
        {
            await Task.Yield();
            await StatsData.EnsureLookupsLoadedAsync();
            await LeagueState.EnsureLoadedAsync();

            _topScoringTeams = StatsData.TopScoringTeams.Take(10).ToList() ?? [];
            _lowScoringTeams = StatsData.LowScoringTeams.Take(10).ToList() ?? [];
            _topScoringPlayers = StatsData.TopScoringPlayers.Take(10).ToList() ?? [];
            _lowScoringPlayers = StatsData.LowScoringPlayers.Take(10).ToList() ?? [];
            _largestMarginOfVictory = StatsData.LargestMarginOfVictory.Take(10).ToList() ?? [];
            _tightestMarginOfVictory = StatsData.TightestMarginOfVictory.Take(10).ToList() ?? [];
            _recordByRosterId = StatsData.SumRecords(StatsData.RecordsBySeason.ToDictionary()) ?? new Dictionary<int, string>();
            _highScoringWeeksByRosterId = StatsData.SumHighScoringWeeks(StatsData.HighScoringWeeksByRosterId.ToDictionary()) ?? new Dictionary<int, int>();
            _lowScoringWeeksByRosterId = StatsData.LowScoringWeeksByRosterId?.ToDictionary() ?? new Dictionary<int, int>();
        }
        catch (Exception ex)
        {
            ILogger.LogError(ex, "ERROR: {Message}", ex.Message);
            _isLoading = false;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
