@page "/history/drafts"
@using Microsoft.VisualBasic
@using Shared.Models
@using Shared.Services
@inject LeagueState LeagueState
@inject DraftState DraftState
@inject PlayerState PlayerState
@inject RosterState RosterState
@inject UserState UserState

<PageTitle>Drafts | @Brand</PageTitle>

<div class="d-flex justify-content-center">
    <h1>Drafts</h1>    
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else if (_draftHistory.Count == 0)
{
    <p role="status">No draft history found.</p>
}
else
{
    <div class="draft-grid-container">
    @foreach (var draft in _draftHistory)
    {
        
        @if (_draftPicks.Where(p => p.DraftId == draft.DraftId).Any())
        {
            <div class="draft-season-container container text-center">   
                <div class="draft-season">@draft.Season Season</div>
            </div>
            <div class="draft-container container text-center common-container">
            <table class="table draft-table">
                <thead>
                <tr>
                @foreach(var team in draft.DraftOrder?.OrderBy(x => x.Key).ToList() ?? [])
                {
                    <th scope="col"
                        class=@($"row-item team-header {(IsSelectedTeam(draft.DraftId, team.Value) ? "team-header-selected" : "")}")
                        @onclick="() => SelectDraftTeam(draft.DraftId, team.Value)">
                            <div>
                                <img class="owner-avatar" src=@(UserState.OwnerAvatarByUserId.TryGetValue(team.Value, out var name) ? name : $"Roster {team.Value}") />
                                <div style="font-size: .9rem;">@(UserState.TeamNameByUserId.TryGetValue(team.Value, out var teamName) ? teamName : "Team Not Found")</div>
                            </div>
                    </th> 
                }
                </tr>
                </thead>
                <tbody>
                @foreach(var row in _draftPicks.Where(p => p.DraftId == draft.DraftId).Chunk(10).ToList()) // 10 picks rer round
                {
                    <tr>
                    @foreach(var pick in row) 
                    {
                        @if(pick is not null && pick.PlayerId is not null)
                        {
                            var pickedPlayer = PlayerState.PlayerById.TryGetValue(pick.PlayerId, out var p) ? p : null;
                            <td scope="row" class="row-item">
                                <div class=@($"pick-container {GetPickContainerClass(pick)}")
                                     style=@($"background-color:var(--{pick?.Metadata?.Position?.ToUpper()});")>
                                    <div class="selection-label">@GetSelectionLabel(pick is not null ? pick : new DraftPicksModel(), draft)</div>
                                    @if (!string.Equals(pick?.OriginalPickOwner, pick?.PickedBy, StringComparison.Ordinal))
                                    {
                                        <img class="owner-avatar-xsmall" title="Drafted by @(UserState.TeamNameByUserId.TryGetValue(pick?.PickedBy ?? "", out var teamName) ? teamName : $"Team Not Found")" 
                                            src=@(UserState.OwnerAvatarByUserId.TryGetValue(pick?.PickedBy ?? "", out var name) ? name : "") />
                                    }
                                    <div class="player-position">@pickedPlayer?.Position</div>
                                    <div class="player-name">@pickedPlayer?.Firstname @pickedPlayer?.Lastname</div>
                                    <div class="player-image-container">
                                        <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(pick?.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp)" >
                                            <img class="player-team-logo" src=@(pickedPlayer?.Team is not null && PlayerState.PlayerNFLTeamImageByAbbr.TryGetValue(pickedPlayer.Team, out var img) ? img : "/images/question-mark.png")/>
                                        </div>
                                    </div>
                                    <div class="player-college">@pickedPlayer?.College</div>
                                    <div class="player-nickname">
                                        @GetPlayerNicknameByUserId(pick?.PickedBy ?? "", pick?.PlayerId ?? "")
                                    </div>
                                </div>
                            </td>
                        }
                    }
                    </tr>
                }
                </tbody>
            </table>
            </div>
        }
    }
    </div>
}

@code {
    private  List<DraftPickSeasonSummary> _draftHistory = [];
    private  List<DraftPicksModel> _draftPicks = [];
    [CascadingParameter(Name = "AppBrand")]
    public string? AppBrand { get; set; }
    private string Brand => string.IsNullOrWhiteSpace(AppBrand) ? "FFL" : AppBrand;

    private bool _isLoading = true;
    private string? _selectedDraftId;
    private string? _selectedPickedBy;

    protected override async Task OnInitializedAsync()
    {
        await LoadDraftHistory();
    }

    /// <summary>
    /// Load draft history beginning from current season until previous leagueId is null/not found
    /// </summary>
    /// <returns></returns>
    private async Task LoadDraftHistory()
    {
        _isLoading = true;
        _draftHistory.Clear();
        _draftPicks.Clear();
        try
        {       
            if(!DraftState.IsLoadedAllDrafts) await DraftState.SetAllDraftDataAsync(forceRefresh: true);
            
            _draftHistory = DraftState.DraftHistory;
            _draftPicks = DraftState.AllDraftPicks ?? [];
        }
        finally
        {
            _isLoading = false;
        }
    }


    /// <summary>
    /// Gets the selection label based on the pick of the draft (ie 1.01, 2.02, 3.06...)
    /// </summary>
    /// <param name="pick"></param>
    /// <param name="draft"></param>
    /// <returns></returns>
    private static string GetSelectionLabel(DraftPicksModel pick, DraftPickSeasonSummary draft)
    {
        var teams = draft.DraftOrder?.Count ?? 10;
        if (teams <= 0)
        {
            teams = 10;
        }
        var pickInRound = ((pick.PickNo - 1) % teams) + 1;
        return $"{pick.Round}.{pickInRound:D2}";
    }


    /// <summary>
    /// When user icon selected on the front end, update _selectedDraftId/_selectedPickedBy
    /// </summary>
    /// <param name="draftId"></param>
    /// <param name="pickedBy"></param>
    private void SelectDraftTeam(string? draftId, string? pickedBy)
    {
        if (string.IsNullOrWhiteSpace(draftId) || string.IsNullOrWhiteSpace(pickedBy))
        {
            return;
        }

        // Toggle off if user clicks the same header again.
        if (string.Equals(_selectedDraftId, draftId, StringComparison.Ordinal) &&
            string.Equals(_selectedPickedBy, pickedBy, StringComparison.Ordinal))
        {
            _selectedDraftId = null;
            _selectedPickedBy = null;
            return;
        }

        _selectedDraftId = draftId;
        _selectedPickedBy = pickedBy;
    }

    /// <summary>
    /// Toggles whether the userid in that draftId was selected for styling
    /// </summary>
    /// <param name="draftId"></param>
    /// <param name="teamUserId"></param>
    /// <returns></returns>
    private bool IsSelectedTeam(string? draftId, string? teamUserId)
    {
        if (string.IsNullOrWhiteSpace(draftId) || string.IsNullOrWhiteSpace(teamUserId))
        {
            return false;
        }

        return string.Equals(_selectedDraftId, draftId, StringComparison.Ordinal) &&
               string.Equals(_selectedPickedBy, teamUserId, StringComparison.Ordinal);
    }


    /// <summary>
    /// Toggles the styling based on the if pick DraftId is in the selectedDraftId and then if the PickedBy of the pick is by the selectedUser
    /// TODO: Add functionality to allow multiple drafts to be selected at once
    /// </summary>
    /// <param name="pick"></param>
    /// <returns></returns>
    private string GetPickContainerClass(DraftPicksModel pick)
    {
        if (string.IsNullOrWhiteSpace(_selectedDraftId) || string.IsNullOrWhiteSpace(_selectedPickedBy))
        {
            return string.Empty;
        }

        if (!string.Equals(_selectedDraftId, pick.DraftId, StringComparison.Ordinal))
        {
            return string.Empty;
        }

        return string.Equals(_selectedPickedBy, pick.PickedBy, StringComparison.Ordinal)
            ? "pick-highlight"
            : "pick-dim";
    }


    /// <summary>
    /// Helper class to get nickname by userid
    /// </summary>
    /// <param name="userId"></param>
    /// <param name="playerId"></param>
    /// <returns></returns>
    public string GetPlayerNicknameByUserId(string userId, string playerId)
    {
        if (string.IsNullOrWhiteSpace(userId) || string.IsNullOrWhiteSpace(playerId)) return "";
        if (!RosterState.RosterIdByUserId.TryGetValue(userId, out var rosterId)) return "";
        return RosterState.PlayerNicknameByRosterId.TryGetValue((rosterId, playerId), out var nick) ? nick : "";
    }
}
