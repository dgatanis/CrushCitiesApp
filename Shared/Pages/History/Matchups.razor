@page "/history/matchups"
@using Shared.Models
@using Shared.Services
@inject MatchupState MatchupState
@inject LeagueState LeagueState
@inject RosterState RosterState
@inject UserState UserState
@inject PlayerState PlayerState

<PageTitle>Matchups | @Brand</PageTitle>

<div class="d-flex justify-content-center">
    <h1>Matchups</h1>    
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else if (_matchups.Count == 0)
{
    <div>No Matchups Found</div>
}
else
{
    <div style="margin-bottom:2rem; margin-top:1rem;" class="d-flex justify-content-center flex-wrap gap-2">
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            @GetDropdownLabel(_selectedRosterId1)
        </button>
        <ul class="dropdown-menu">
            @if (_rosters is not null && _rosters.Count > 0)
            {
                @foreach (var roster in _rosters.Where(r => (_selectedRosterId2 == -1 || r.RosterId != _selectedRosterId2) && r.RosterId != _selectedRosterId1)
                                                            .OrderBy(r => r.RosterId))
                {
                    <li>
                        <button class="dropdown-item" type="button" @onclick="() => _selectedRosterId1 = roster.RosterId">
                            @(RosterState.TeamNameByRosterId.TryGetValue(roster.RosterId, out var name) ? name : $"Roster {roster.RosterId}")
                        </button>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                }
                    <li>
                        <button class="dropdown-item" type="button" @onclick="() => {_selectedRosterId1 = -1;}">
                        --Reset--
                        </button>
                    </li>
            }
            else
            {
                <li><span class="dropdown-item-text">No rosters loaded</span></li>
            }
        </ul>
    </div>
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            @GetDropdownLabel(_selectedRosterId2)
        </button>
        <ul class="dropdown-menu">
            @if (_rosters is not null && _rosters.Count > 0)
            {
                @foreach (var roster in _rosters.Where(r => (_selectedRosterId1 == -1 || r.RosterId != _selectedRosterId1) && r.RosterId != _selectedRosterId2)
                                                            .OrderBy(r => r.RosterId))
                {
                    <li>
                        <button class="dropdown-item" type="button" @onclick="() => _selectedRosterId2 = roster.RosterId">
                            @(RosterState.TeamNameByRosterId.TryGetValue(roster.RosterId, out var name) ? name : $"Roster {roster.RosterId}")
                        </button>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                }
                    <li>
                        <button class="dropdown-item" type="button" @onclick="() => {_selectedRosterId2 = -1;}">
                        --Reset--
                        </button>
                    </li>
            }
            else
            {
                <li><span class="dropdown-item-text">No rosters loaded</span></li>
            }
        </ul>
    </div>
    </div>
    <div class="accordion" id="accordionSeasons">
        @foreach (var seasonGroup in _matchups
            .Where(m => !string.IsNullOrWhiteSpace(m.Season))
            .GroupBy(m => m.Season!)
            .OrderByDescending(g => g.Key))
        {
            var season = seasonGroup.Key;
            var seasonCollapseId = $"collapseSeason{season}";

            <div class="accordion-item" style="background: var(--faded-background);">
                <h2 class="accordion-header" id="@($"headingSeason{season}")">
                    <button class="accordion-button collapsed faded show" type="button" data-bs-toggle="collapse" data-bs-target="@($"#{seasonCollapseId}")" aria-expanded="false" aria-controls="@seasonCollapseId">
                        Season @season
                    </button>
                </h2>
                <div id="@seasonCollapseId" class="accordion-collapse collapse" data-bs-parent="#accordionSeasons">
                    <div class="accordion-body">
                        <div class="accordion" id="@($"accordionWeeks{season}")">
                            @foreach (var weekGroup in seasonGroup
                                .Where(m => !string.IsNullOrWhiteSpace(m.Week))
                                .GroupBy(m => m.Week)
                                .OrderBy(g => int.TryParse(g.Key, out var weekNumber) ? weekNumber : int.MaxValue)
                                .Where(ShouldShowMatchup))
                            {
                                var week = weekGroup.Key;
                                var weekCollapseId = $"collapseWeek{season}_{week}";
                                var weekLabel = int.Parse(week ?? "0") == 15 ? "Playoffs Round 1" : int.Parse(week ?? "0") == 16 ? "Semifinals" : int.Parse(week ?? "0") == 17 ? "Finals" : $"Week {week}";

                                <div class="accordion-item" style="background: transparent;background: transparent;box-shadow: unset !important;border: unset !important;">
                                    <h2 class="accordion-header" id="@($"headingWeek{season}_{week}")">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="@($"#{weekCollapseId}")" aria-expanded="false" aria-controls="@weekCollapseId">
                                            @weekLabel
                                        </button>
                                    </h2>
                                    <div id="@weekCollapseId" class="accordion-collapse collapse" data-bs-parent="@($"#accordionWeeks{season}")">
                                        <div class="accordion-body inner-accordion-body">
                                            @foreach (var matchupPartition in weekGroup
                                                .GroupBy(m => m.MatchupId)
                                                .OrderBy(g => g.Key ?? int.MaxValue)
                                                .Where(ShouldShowMatchup))
                                            {
                                                var winnerRosterId = GetWinnerRosterId(matchupPartition);
                                                var matchupKey = matchupPartition.Key?.ToString() ?? "na";
                                                var teams = matchupPartition.OrderBy(m => m.RosterId).ToList();

                                                <div class="mb-3 p-2 border rounded">
                                                    <div class="row g-2 mt-1 justify-content-center align-items-center matchup-row">
                                                        @for (var i = 0; i < teams.Count; i++)
                                                        {
                                                            var team = teams[i];
                                                            var roster = _rosters?.FirstOrDefault(r => r.RosterId == team.RosterId);
                                                            var teamCollapseId = $"collapseTeam{season}_{week}_{matchupKey}";
                                                            <div class="col-12 col-md-5 matchup-team-col">
                                                                <div class="common-container matchup-team-card p-2 border-3 border rounded">
                                                                    <button class="matchup-team-toggle" type="button" data-bs-toggle="collapse" data-bs-target="@($"#{teamCollapseId}")" aria-expanded="false" aria-controls="@teamCollapseId">
                                                                        <div class="matchup-team-header">
                                                                            <div class="matchup-team-header-left">
                                                                                @if (roster is not null && !string.IsNullOrWhiteSpace(roster.OwnerId))
                                                                                {
                                                                                    <img class="owner-avatar" src=@(UserState.OwnerAvatarByUserId.TryGetValue(roster.OwnerId, out var name) ? name : $"Roster {roster.OwnerId}")>
                                                                                }
                                                                                <div class="matchup-team-name">@(RosterState.TeamNameByRosterId.TryGetValue(team.RosterId, out var teamName) ? teamName : $"Roster {team.RosterId}")</div>
                                                                                <div class="matchup-team-record badge text-warning border border-warning align-items-center text-nowrap">@GetRecordDisplay(season, week ?? "", team.RosterId)</div>
                                                                            </div>
                                                                            <div class="matchup-team-score" style="color: var(--@(winnerRosterId.HasValue && winnerRosterId.Value == team.RosterId ? "added" : "dropped"))">@team.Points</div>
                                                                        </div>
                                                                    </button>
                                                                    <div id="@teamCollapseId" class="collapse matchup-team-body">
                                                                        @{
                                                                            var slotIndex = 0;
                                                                        }
                                                                        @foreach(var playerId in team.Starters ?? [])
                                                                        {
                                                                            slotIndex++;
                                                                            var player = PlayerState.PlayerById.TryGetValue(playerId, out var p) ? p : null;
                                                                            var positionLabel = slotIndex == 7 || slotIndex == 8 ? "FLEX" : slotIndex == 9 ? "SF" : player?.Position;

                                                                            <div class="player-row">
                                                                                <div class="player-position" style="color:var(--@(player?.Position?.ToUpper()))">@positionLabel</div>
                                                                                <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(player?.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp); border-color:var(--@(player?.Position?.ToUpper()))"></div>
                                                                                <div class="player-name">@((player is not null) ? $"{player.Firstname} {player.Lastname}" : "")</div>
                                                                                <div class="player-points">@(team.PlayersPoints?.Count() > 0 ? team.PlayersPoints.FirstOrDefault(x => x.Key == playerId).Value : "")</div>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            @if (i == 0 && teams.Count > 1)
                                                            {
                                                                <div class="col-12 col-md-2 matchup-vs-col">
                                                                    <div class="matchup-vs-wrap">
                                                                        <img class="matchup-vs-img" src="/images/matchup_versus.png" alt="Versus">
                                                                    </div>
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "AppBrand")]
    public string? AppBrand { get; set; }
    private string Brand => string.IsNullOrWhiteSpace(AppBrand) ? "FFL" : AppBrand;
    private List<MatchupModel> _matchups = [];
    private bool _isLoading = true;
    private List<RostersModel>? _rosters = null;
    private int _selectedRosterId1 = -1;
    private int _selectedRosterId2 = -1;
    private readonly Dictionary<string, SeasonRecord> _recordsBySeason = new();



    protected override void OnInitialized()
    {
        _isLoading = true;
        _ = LoadPageAsync();
    }

    /// <summary>
    /// Loads all elements needed for the page
    /// </summary>
    /// <returns></returns>
    private  async Task LoadPageAsync()
    {
        try
        {
            await Task.Yield(); 
            await LoadMatchupsAsync(); 
            if(!PlayerState.CacheLoaded)
            {
                await PlayerState.BuildLookupCachesAsync(); 
            }
            await LoadRosters();
            
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Loads All Matchups 
    /// </summary>
    /// <returns></returns>
    private async Task LoadMatchupsAsync()
    {
        await MatchupState.EnsureLoadedAsync();
        _matchups = MatchupState.AllMatchups ?? [];
        BuildRecords();
    }


    /// <summary>
    /// Loads Rosters 
    /// </summary>
    /// <returns></returns>
    private async Task LoadRosters()
    {
        await RosterState.EnsureLoadedAsync();
        await RosterState.EnsureCacheLoadedAsync();
        _rosters = RosterState.Rosters;
    }


    /// <summary>
    /// Calculates the winner based on the matchup
    /// </summary>
    /// <param name="teams"></param>
    /// <returns></returns>
    private static int? GetWinnerRosterId(IEnumerable<MatchupModel> teams)
    {
        var ordered = teams.OrderByDescending(t => t.Points).ToList();
        if (ordered.Count == 0)
        {
            return null;
        }

        var topPoints = ordered[0].Points;
        var topCount = ordered.Count(t => t.Points == topPoints);
        return topCount > 1 ? null : ordered[0].RosterId;
    }

    /// <summary>
    /// Gets the roster names for dropdowns 
    /// </summary>
    /// <param name="rosterId"></param>
    /// <returns></returns>
    private string GetDropdownLabel(int rosterId)
    {
        if (rosterId == -1) return "Filter by team";
        return RosterState.TeamNameByRosterId.TryGetValue(rosterId, out var name)
            ? name
            : $"Roster {rosterId}";
    }

    /// <summary>
    /// Based on the selections in the dropdowns (neither dropdown is required) show matchups for those _selectedRosterId/s
    /// </summary>
    /// <param name="group"></param>
    /// <returns></returns>
    private bool ShouldShowMatchup(IEnumerable<MatchupModel> group)
    {
        // no filters -> show all weeks/matchups
        if (_selectedRosterId1 == -1 && _selectedRosterId2 == -1)
            return true;

        // one roster selected -> show if week has that roster anywhere
        if (_selectedRosterId1 != -1 && _selectedRosterId2 == -1)
            return group.Any(m => m.RosterId == _selectedRosterId1);

        if (_selectedRosterId1 == -1 && _selectedRosterId2 != -1)
            return group.Any(m => m.RosterId == _selectedRosterId2);

        // show only if at least one matchup in this week has both rosters
        return group
            .GroupBy(m => m.MatchupId)
            .Any(g =>
            {
                var ids = g.Select(x => x.RosterId).ToHashSet();
                return ids.Contains(_selectedRosterId1) && ids.Contains(_selectedRosterId2);
            });
    }

    /// <summary>
    /// Reload all of the matchups
    /// </summary>
    /// <returns></returns>
    private async Task ReloadMatchups()
    {
        _isLoading = true;
        MatchupState.ClearAllMatchups();
        await LoadMatchupsAsync();
        _matchups = MatchupState.AllMatchups ?? [];
        BuildRecords();
        _isLoading = false;
    }

    /// <summary>
    /// Builds a lookup of records by season/ week / rosterid to avoid having to calculate records on the fly while rendering
    /// </summary>
    private void BuildRecords()
    {
        _recordsBySeason.Clear();
        var seasonGroups = _matchups
            .Where(m => !string.IsNullOrWhiteSpace(m.Season) && !string.IsNullOrWhiteSpace(m.Week))
            .GroupBy(m => m.Season!);

        foreach (var seasonGroup in seasonGroups)
        {
            var season = seasonGroup.Key;
            var weekGroups = seasonGroup
                .Select(m => new { Matchup = m, WeekNumber = int.TryParse(m.Week, out var num) ? num : -1 })
                .Where(x => x.WeekNumber != -1)
                .GroupBy(x => x.WeekNumber!)
                .OrderBy(g => g.Key);

            var cumulative = new Dictionary<int, Record>();
            var seasonRecord = new SeasonRecord(season);

            foreach (var weekGroup in weekGroups)
            {
                var matchupsThisWeek = weekGroup.Select(x => x.Matchup);
                foreach (var matchupPartition in matchupsThisWeek.GroupBy(m => m.MatchupId))
                {
                    var winnerRosterId = GetWinnerRosterId(matchupPartition);
                    foreach (var team in matchupPartition)
                    {
                        if (!cumulative.TryGetValue(team.RosterId, out var current))
                        {
                            current = new Record();
                            cumulative[team.RosterId] = current;
                        }
                        if (!winnerRosterId.HasValue)
                        {
                            current.Ties += 1;
                        }
                        else if (winnerRosterId.Value == team.RosterId)
                        {
                            current.Wins += 1;
                        }
                        else
                        {
                            current.Losses += 1;
                        }
                    }
                }

                var weekRecord = new WeekRecord(weekGroup.Key);
                foreach (var entry in cumulative)
                {
                    weekRecord.ByRoster[entry.Key] = new Record
                    {
                        Wins = entry.Value.Wins,
                        Losses = entry.Value.Losses,
                        Ties = entry.Value.Ties
                    };
                }

                seasonRecord.WeeksByNumber[weekGroup.Key] = weekRecord;
            }

            _recordsBySeason[season] = seasonRecord;
        }
    }

    private string GetRecordDisplay(string season, string week, int rosterId)
    {
        int? weekNumber = int.TryParse(week, out var weekNum) ? weekNum : null;
        if (!weekNumber.HasValue)
        {
            return string.Empty;
        }

        if (_recordsBySeason.TryGetValue(season, out var seasonRecord) &&
            seasonRecord.WeeksByNumber.TryGetValue(weekNumber.Value, out var weekRecord) &&
            weekRecord.ByRoster.TryGetValue(rosterId, out var record))
        {
            return record.Display;
        }

        return string.Empty;
    }

    private static int? ParseWeekNumber(string? week)
    {
        return int.TryParse(week, out var weekNumber) ? weekNumber : null;
    }

    private sealed class Record
    {
        public int Wins { get; set; }
        public int Losses { get; set; }
        public int Ties { get; set; }
        public string Display => Ties > 0 ? $"{Wins}-{Losses}-{Ties}" : $"{Wins}-{Losses}";
    }

    private sealed class WeekRecord
    {
        public WeekRecord(int weekNumber)
        {
            WeekNumber = weekNumber;
        }

        public int WeekNumber { get; }
        public Dictionary<int, Record> ByRoster { get; } = new();
    }

    private sealed class SeasonRecord
    {
        public SeasonRecord(string season)
        {
            Season = season;
        }

        public string Season { get; }
        public Dictionary<int, WeekRecord> WeeksByNumber { get; } = new();
    }

}
