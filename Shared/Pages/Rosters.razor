@page "/rosters"
@using Shared.Models
@using Shared.Services
@inject UserState UserState
@inject RosterState RosterState
@inject PlayerState PlayerState
@inject LeagueState LeagueState

<PageTitle>Rosters | @Brand</PageTitle>

<div class="d-flex justify-content-center">
    <h1>Rosters</h1>    
</div>

@if (_isLoading)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Dots" Class="me-3" Color="SpinnerColor.Primary" Size="SpinnerSize.Large" />
    </div>
}
else
{
    <div class="rosters-page-container">
    @foreach (var roster in _rosters ?? [])
    {
        _counter = 0;
        <div class="roster-container">
        
            @if (!string.IsNullOrWhiteSpace(roster.OwnerId))
            {
                <div class="owner-info d-flex flex-column align-items-center mb-1">
                    <img class="owner-avatar" src=@(UserState.OwnerAvatarByUserId.TryGetValue(roster.OwnerId, out var name) ? name : $"Roster {roster.OwnerId}")>
                    <span class="team-name">@(UserState.TeamNameByUserId.TryGetValue(roster.OwnerId, out var teamName) ? teamName : "")</span>
                </div>
            }
            <div class="accordion" id="@($"accordionStarters{roster.RosterId}")">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="@($"#collapseStarters{roster.RosterId}")" aria-expanded="true" aria-controls="@($"collapseStarters{roster.RosterId}")">
                        Starters
                    </button>
                    </h2>
                    <div id=@($"collapseStarters{roster.RosterId}") class="accordion-collapse collapse show" data-bs-parent="@($"#accordionStarters{roster.RosterId}")">
                    <div class="accordion-body">
                        @foreach(var starter in roster.Starters ?? [])
                        {
                            _counter++;
                            var player = PlayerState.PlayerById.TryGetValue(starter, out var p) ? p : null;
                            if(player is not null)
                            {
                                <div class="player-container border border-1 rounded-end" style="background-color:@(player?.Position is not null ? $"var(--{player?.Position.ToUpper()}-faded)" : "grey")">
                                    <div class="position-container">
                                        <div class="player-position">
                                            @(_counter == 7 || _counter == 8 ? "FLEX": _counter == 9 ? "SF": player?.Position)
                                        </div>
                                    </div> 
                                    <div class="player-image-container">
                                        <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(player?.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp); border-color:var(--@(player?.Position?.ToUpper()))"></div>
                                    </div>
                                    <div class="player-name-container">
                                        <div class="player-name">@player?.Firstname @player?.Lastname</div>
                                        <img class="player-team-logo" src=@(player?.Team is not null && PlayerState.PlayerNFLTeamImageByAbbr.TryGetValue(player.Team, out var img) ? img : "/images/question-mark.png")>
                                    </div>
                                    <div class="player-details">
                                        <span class="player-number">#@player?.Number</span>
                                        <span class="player-age">Age: @player?.Age</span>  
                                        <span class="player-height">@GetHeightString(player?.Height)</span>  
                                        <span class="player-weight">@player?.Weight lbs</span>  
                                    </div>
                                    <div class="player-nickname">@(RosterState.PlayerNicknameByRosterId.TryGetValue((roster.RosterId, player?.PlayerId ?? ""), out var nickname) ? nickname : "")</div>
                                    <a title="View Player on Rotowire" target="_blank" href=@($"https://www.rotowire.com/football/player/{player?.Firstname?.ToLower()}-{player?.Lastname?.ToLower()}-{player?.RotowireId}")>
                                        <span class="bi-search-icon"></span>
                                    </a>
                                </div>
                            }
                        }
                    </div>
                    </div>
                </div>
            </div>
            <div class="accordion" id="@($"accordionBench{roster.RosterId}")">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="@($"#collapseBench{roster.RosterId}")" aria-expanded="true" aria-controls="@($"collapseBench{roster.RosterId}")">
                        Bench
                    </button>
                    </h2>
                    <div id=@($"collapseBench{roster.RosterId}") class="accordion-collapse collapse" data-bs-parent="@($"#accordionBench{roster.RosterId}")">
                    <div class="accordion-body">
                        @foreach(var bench in roster.Players ?? [])
                        {
                            if(roster.Starters is not null && !roster.Starters.Contains(bench) && !roster.Taxi!.Contains(bench))
                            {
                                var player = PlayerState.PlayerById.TryGetValue(bench, out var p) ? p : null;
                                <div class="player-container border border-1 rounded-end" style="background-color:#6e6e6eb5;">
                                    <div class="position-container">
                                        <div class="player-position">
                                            @player?.Position
                                        </div>
                                    </div> 
                                    <div class="player-image-container">
                                        <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(player?.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp); border-color:var(--@(player?.Position?.ToUpper()))"></div>
                                    </div>
                                    <div class="player-name-container">
                                        <div class="player-name">@player?.Firstname @player?.Lastname</div>
                                        <img class="player-team-logo" src=@(player?.Team is not null && PlayerState.PlayerNFLTeamImageByAbbr.TryGetValue(player.Team, out var img) ? img : "/images/question-mark.png")>
                                    </div>
                                    <div class="player-details">
                                        <span class="player-number">#@player?.Number</span>
                                        <span class="player-age">Age: @player?.Age</span>  
                                        <span class="player-height">@GetHeightString(player?.Height)</span>  
                                        <span class="player-weight">@player?.Weight lbs</span>  
                                    </div>
                                    <div class="player-nickname">@(RosterState.PlayerNicknameByRosterId.TryGetValue((roster.RosterId, player?.PlayerId ?? ""), out var nickname) ? nickname : "")</div>
                                    <a title="View Player on Rotowire" target="_blank" href=@($"https://www.rotowire.com/football/player/{player?.Firstname?.ToLower()}-{player?.Lastname?.ToLower()}-{player?.RotowireId}")>
                                        <span class="bi-search-icon"></span>
                                    </a>
                                </div>
                            }
                        }
                    </div>
                    </div>
                </div>
            </div>

            <div class="accordion" id="@($"accordionTaxi{roster.RosterId}")">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="@($"#collapseTaxi{roster.RosterId}")" aria-expanded="true" aria-controls="@($"collapseTaxi{roster.RosterId}")">
                        Taxi
                    </button>
                    </h2>
                    <div id=@($"collapseTaxi{roster.RosterId}") class="accordion-collapse collapse" data-bs-parent="@($"#accordionTaxi{roster.RosterId}")">
                    <div class="accordion-body">
                        @foreach(var taxi in roster.Taxi ?? [])
                        {
                            var player = PlayerState.PlayerById.TryGetValue(taxi, out var p) ? p : null;
                            <div class="player-container border border-1 rounded-end" style="background-color:#6e6e6eb5;">
                                <div class="position-container">
                                    <div class="player-position">
                                        @player?.Position
                                    </div>
                                </div> 
                                <div class="player-image-container">
                                    <div class="player-image" style="background-image: url(https://sleepercdn.com/content/nfl/players/thumb/@(player?.PlayerId).jpg), url(https://sleepercdn.com/images/v2/icons/player_default.webp); border-color:var(--@(player?.Position?.ToUpper()))"></div>
                                </div>
                                <div class="player-name-container">
                                    <div class="player-name">@player?.Firstname @player?.Lastname</div>
                                    <img class="player-team-logo" src=@(player?.Team is not null && PlayerState.PlayerNFLTeamImageByAbbr.TryGetValue(player.Team, out var img) ? img : "/images/question-mark.png")>
                                </div>
                                <div class="player-details">
                                    <span class="player-number">#@player?.Number</span>
                                    <span class="player-age">Age: @player?.Age</span>  
                                    <span class="player-height">@GetHeightString(player?.Height)</span>  
                                    <span class="player-weight">@player?.Weight lbs</span>  
                                </div>
                                <div class="player-nickname">@(RosterState.PlayerNicknameByRosterId.TryGetValue((roster.RosterId, player?.PlayerId ?? ""), out var nickname) ? nickname : "")</div>
                                <a title="View Player on Rotowire" target="_blank" href=@($"https://www.rotowire.com/football/player/{player?.Firstname?.ToLower()}-{player?.Lastname?.ToLower()}-{player?.RotowireId}")>
                                    <span class="bi-search-icon"></span>
                                </a>
                            </div>
                        }
                    </div>
                    </div>
                </div>
            </div>

        </div>
    }
    </div>
}



@code {
    private List<RostersModel>? _rosters = new List<RostersModel>();
    [CascadingParameter(Name = "AppBrand")]
    private string? AppBrand { get; set; }
    private string Brand => string.IsNullOrWhiteSpace(AppBrand) ? "FFL" : AppBrand;
    private bool _isLoading = true;
    private int _counter = 0;

    protected override async Task OnInitializedAsync()
    {
        if(!PlayerState.CacheLoaded)
        {
            await PlayerState.BuildLookupCachesAsync(); 
        }
        
        await RosterState.EnsureLoadedAsync();
        await UserState.EnsureCacheLoadedAsync();
        _rosters = RosterState.Rosters;
        _isLoading = false;
    }

    /// <summary>
    /// Returns the height in feet/inches
    /// </summary>
    /// <param name="heightInInches"></param>
    /// <returns></returns>
    private string GetHeightString(string? heightInInches)
    {
        if (heightInInches == null) return "N/A";
        int feet = int.Parse(heightInInches) / 12;
        int inches = int.Parse(heightInInches) % 12;
        return $"{feet}'{inches}\"";
    }
}