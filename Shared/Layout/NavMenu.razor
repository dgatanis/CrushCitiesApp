<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@Brand</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <button class="nav-link history-toggle" @onclick="ToggleHistoryMenu" @onclick:stopPropagation="true">
            <span class="bi bi-history-nav-menu" aria-hidden="true"></span> History
            </button>
                @if (showHistoryMenu)
                {
                    <div class="history-sub">
                        <NavLink class="nav-link" href="history/current-season">Current Season</NavLink>
                        <NavLink class="nav-link" href="history/drafts">Drafts</NavLink>
                        <NavLink class="nav-link" href="history/champs">League Champs</NavLink>
                        <NavLink class="nav-link" href="history/matchups">Matchups</NavLink>
                        <NavLink class="nav-link" href="history/stats">Stats</NavLink>
                    </div>
                }
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="rosters">
                <span class="bi bi-rosters-nav-menu" aria-hidden="true"></span> Rosters
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="trades">
                <span class="bi bi-trades-nav-menu" aria-hidden="true"></span> Trades
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="rankings">
                <span class="bi bi-rankings-nav-menu" aria-hidden="true"></span> Power Rankings
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter] public string Brand { get; set; } = "FFL";

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private bool showHistoryMenu;

    private void ToggleHistoryMenu()
    {
        showHistoryMenu = !showHistoryMenu;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
