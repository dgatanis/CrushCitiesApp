{
  "globalHeaders": {
    "Content-Security-Policy": "default-src 'self';base-uri 'self';object-src 'none';frame-ancestors 'self';form-action 'self';img-src 'self' https: data:;font-src 'self' data:;style-src 'self' 'unsafe-inline';script-src 'self' 'wasm-unsafe-eval' https://static.cloudflareinsights.com https://cdnjs.cloudflare.com;script-src-elem 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://cdnjs.cloudflare.com;connect-src 'self' https://api.sleeper.app https://sleeperfunctions-cjc2cqgwfbfsaeg4.westus2-01.azurewebsites.net;worker-src 'self' blob:;",
     "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
    "X-Frame-Options": "DENY"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/css/*",
      "/js/*",
      "/images/*",
      "/lib/*",
      "/_framework/*",
      "/_content/*",
      "/Fonts/*",
      "/*.css",
      "/*.js",
      "/*.json",
      "/*.wasm",
      "/*.png",
      "/*.jpg",
      "/*.svg",
      "/*.ico",
      "/*.webp",
      "/*.woff",
      "/*.woff2",
      "/*.ttf",
      "/*.otf"
    ]
  },
  "routes": [
    { "route": "/Fonts/*", "allowedRoles": ["anonymous"] },
    { "route": "/css/*", "allowedRoles": ["anonymous"] },
    { "route": "/js/*", "allowedRoles": ["anonymous"] },
    { "route": "/images/*", "allowedRoles": ["anonymous"] },
    { "route": "/lib/*", "allowedRoles": ["anonymous"] },
    { "route": "/_framework/*", "allowedRoles": ["anonymous"] },
    { "route": "/_content/*", "allowedRoles": ["anonymous"] },
    { "route": "/*.css", "allowedRoles": ["anonymous"] },
    { "route": "/*.js", "allowedRoles": ["anonymous"] },
    { "route": "/*.json", "allowedRoles": ["anonymous"] },
    { "route": "/*.wasm", "allowedRoles": ["anonymous"] },
    { "route": "/*.png", "allowedRoles": ["anonymous"] },
    { "route": "/*.jpg", "allowedRoles": ["anonymous"] },
    { "route": "/*.svg", "allowedRoles": ["anonymous"] },
    { "route": "/*.ico", "allowedRoles": ["anonymous"] },
    { "route": "/*.webp", "allowedRoles": ["anonymous"] },
    { "route": "/*.woff", "allowedRoles": ["anonymous"] },
    { "route": "/*.woff2", "allowedRoles": ["anonymous"] },
    { "route": "/*.ttf", "allowedRoles": ["anonymous"] },
    { "route": "/*.otf", "allowedRoles": ["anonymous"] },
    { "route": "/Login.html", "allowedRoles": ["anonymous"] },
    { "route": "/Unauthorized.html", "allowedRoles": ["anonymous"] },
    { "route": "/*", "allowedRoles": ["internal"] }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer"
    },
    "403": {
      "rewrite": "/Unauthorized.html"
    }
  }
}